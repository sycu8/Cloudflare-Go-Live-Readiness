{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cf-ready-docs",
  "main": "workers/src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "html_handling": "auto-trailing-slash"
  },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "lite",
      "max_instances": 10
    }
  ],
  "durable_objects": {
    "bindings": [
      { "class_name": "Sandbox", "name": "Sandbox" },
      { "class_name": "SessionDO", "name": "SESSION" }
    ]
  },
  "migrations": [
    { "new_sqlite_classes": ["Sandbox", "SessionDO"], "tag": "v1" }
  ],
  "r2_buckets": [
    { "binding": "UPLOADS", "bucket_name": "cf-ready-uploads" }
  ],
  "kv_namespaces": [
    { "binding": "SESSIONS", "id": "00000000000000000000000000000000", "preview_id": "00000000000000000000000000000001" }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cf-ready",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations/d1"
    }
  ],
  "vars": {
    "DEFAULT_AI_MODEL": "openai/gpt-4o-mini",
    "FALLBACK_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct-fast",
    "AI_GATEWAY_ID": "default",
    "SANDBOX_TRANSPORT": "rpc",
    "WORKER_PUBLIC_URL": "https://ready.orangecloud.vn",
    "GITHUB_REDIRECT_URI": "https://ready.orangecloud.vn/api/auth/github/callback",
    "GOOGLE_REDIRECT_URI": "https://ready.orangecloud.vn/api/auth/google/callback"
  },
  "observability": {
    "enabled": true,
    "logs": {
      "invocation_logs": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true
    }
  }
}
