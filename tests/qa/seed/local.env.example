# Production-like local settings (copy to .dev.vars for wrangler dev — never commit secrets)
WORKER_PUBLIC_URL=http://localhost:8787
GITHUB_REDIRECT_URI=http://localhost:8787/api/auth/github/callback
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

# Optional OAuth (omit both pairs for open-mode QA)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# AI / optimize (optional)
# AI_API_KEY=
