{
  "name": "@orangecloud/cf-ready",
  "version": "0.1.0",
  "description": "Cloudflare Go-Live Readiness CLI — migration, security, AI, SEO, and deployment readiness checks",
  "type": "module",
  "license": "MIT",
  "author": "OrangeCloud",
  "repository": {
    "type": "git",
    "url": "https://github.com/sycu8/Cloudflare-Go-Live-Readiness.git"
  },
  "homepage": "https://ready.orangecloud.vn",
  "bugs": {
    "url": "https://github.com/sycu8/Cloudflare-Go-Live-Readiness/issues"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "pages",
    "readiness",
    "migration",
    "security",
    "seo",
    "cli",
    "devops",
    "nextjs",
    "vite"
  ],
  "bin": {
    "cf-ready": "./dist/index.js"
  },
  "files": [
    "dist",
    "examples",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "node scripts/build-public.mjs",
    "build:all": "npm run build && npm run build:web",
    "generate:og": "node scripts/generate-og.mjs",
    "dev": "tsup --watch",
    "dev:web": "npm run build:web && wrangler dev",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.workers.json",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:web-agent": "vitest run tests/integration/web-agent-commands.test.ts",
    "test:e2e": "node scripts/e2e-web-agent.mjs",
    "prepublishOnly": "npm run build",
    "pages:deploy": "npm run build:all && wrangler deploy"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cloudflare/sandbox": "^0.12.3",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "pdf-lib": "^1.17.1",
    "picocolors": "^1.1.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9",
    "wrangler": "^4.108.0"
  }
}
